# =============================================================================
# Restaurant Recommendation System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# --- Logging ---
# Set to DEBUG for development, INFO for production
LOG_LEVEL=INFO

# --- Groq LLM Configuration ---
# API key from https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# Model identifier (default: llama-3.3-70b-versatile)
# Alternatives: llama-3.1-8b-instant (faster, lower cost for dev)
GROQ_MODEL=llama-3.3-70b-versatile

# Timeout for Groq API calls (seconds)
GROQ_TIMEOUT=30

# Number of retries on transient Groq failures
GROQ_MAX_RETRIES=1

# --- Dataset Configuration ---
# Hugging Face dataset identifier
DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# --- Recommendation Pipeline ---
# Maximum candidates passed to the LLM after filtering
MAX_CANDIDATES=30

# Default number of recommendations returned to the user
DEFAULT_TOP_K=5

# --- Budget Tier Thresholds (₹) ---
# cost_for_two <= BUDGET_LOW_MAX  → "low"
# cost_for_two <= BUDGET_MEDIUM_MAX → "medium"
# cost_for_two >  BUDGET_MEDIUM_MAX → "high"
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500
